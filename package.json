{
	"name": "cap-worker",
	"description": "Cloudflare Worker implementation of a Cap-compatible proof-of-work challenge service.",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"cap",
		"captcha",
		"cloudflare-workers",
		"durable-objects",
		"hono",
		"proof-of-work"
	],
	"scripts": {
		"dev": "wrangler dev",
		"build": "wrangler deploy --dry-run --outdir dist",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"check": "biome check .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"hono": "^4.12.16"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5",
		"wrangler": "^4.87.0"
	}
}
